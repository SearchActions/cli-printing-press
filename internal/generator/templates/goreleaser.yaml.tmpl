version: 2
project_name: {{.Name}}-cli
changelog:
  disable: true
builds:
  - id: {{.Name}}-cli
    main: ./cmd/{{.Name}}-cli
    binary: {{.Name}}-cli
    env:
      - CGO_ENABLED=0
    ldflags:
      - -s -w -X github.com/{{.Owner}}/{{.Name}}-cli/internal/cli.version={{"{{"}} .Version {{"}}"}}
    targets:
      - darwin_amd64
      - darwin_arm64
      - linux_amd64
      - linux_arm64
      - windows_amd64
      - windows_arm64
{{- if .VisionSet.MCP}}
  - id: {{.Name}}-mcp
    main: ./cmd/{{.Name}}-mcp
    binary: {{.Name}}-mcp
    env:
      - CGO_ENABLED=0
    ldflags:
      - -s -w
    targets:
      - darwin_amd64
      - darwin_arm64
      - linux_amd64
      - linux_arm64
      - windows_amd64
      - windows_arm64
{{- end}}
archives:
  - formats: [tar.gz]
    name_template: "{{"{{"}} .ProjectName {{"}}"}}_{{"{{"}} .Version {{"}}"}}_{{"{{"}} .Os {{"}}"}}_{{"{{"}} .Arch {{"}}"}}"
    format_overrides:
      - goos: windows
        formats: [zip]
checksum:
  name_template: checksums.txt
brews:
  - name: {{.Name}}-cli
    repository:
      owner: {{.Owner}}
      name: homebrew-tap
    homepage: "https://github.com/{{.Owner}}/{{.Name}}-cli"
    description: "{{.Description}}"
    install: |
      bin.install "{{.Name}}-cli"
{{- if .VisionSet.MCP}}
      bin.install "{{.Name}}-mcp"
{{- end}}
