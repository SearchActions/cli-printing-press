.PHONY: build test lint install clean

build:
	go build -o bin/{{.Name}}-cli ./cmd/{{.Name}}-cli

test:
	go test ./...

lint:
	golangci-lint run

install:
	go install ./cmd/{{.Name}}-cli

clean:
	rm -rf bin/
{{- if .VisionSet.MCP}}

build-mcp:
	go build -o bin/{{.Name}}-mcp ./cmd/{{.Name}}-mcp

install-mcp:
	go install ./cmd/{{.Name}}-mcp

build-all: build build-mcp
{{- end}}
